  "type": "decimal",
  "query": {
    "select": {
      "default": "(((AMASUM.TotalMalesWeights + AMASUM.TotalFemalesWeights)*1.00) / NULLIF((AMASUM.TotalMalesBorn + AMASUM.TotalFemalesBorn), 0)) / NULLIF(AMASUM.LastDeliveryNumber, 0)"
    }
  },
  "format": {
    "name": "MksFormatter",
    "params": [ "mass" ]
  },  
  "description": {
    "en": "Average total births per delivery",
    "es": "Peso promedio nacidos por parto",
    "pt": "Média total de nascimentos por parto"
  }
}