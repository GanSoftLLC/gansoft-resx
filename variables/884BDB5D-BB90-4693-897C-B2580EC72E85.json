  "type": "decimal",
  "query": {
    "select": {
      "default": "((AMASUM.TotalMalesAlive + AMASUM.TotalFemalesAlive)*1.00) / NULLIF(AMASUM.LastDeliveryNumber, 0)"
    }
  },
  "format": {
    "name": "NumberFormatter",
    "params": [ 2 ]
  },  
  "description": {
    "en": "Average total births per delivery",
    "es": "Promedio total nacidos vivos por parto",
    "pt": "Média total de nascimentos por parto"
  }
}